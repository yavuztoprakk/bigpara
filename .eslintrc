{
    "parser": "babel-eslint",
    "extends": [
      "standard",
      "standard-react"
    ],
    "plugins": [
      "babel",
      "react",
      "promise"
    ],
    "env": {
      "browser": true
    },
    "globals": {
      "__DEV__": false,
      "__TEST__": false,
      "__PROD__": false,
      "__COVERAGE__": false
    },
    "rules": {
      "key-spacing": "off",
      "no-tabs": "off",
      "jsx-quotes": [
        "error",
        "prefer-double"
      ],
      "quotes": [
        "error",
        "double"
      ],
      "space-before-function-paren": [
        "error",
        "never"
      ],
      "max-len": [
        2,
        120,
        2
      ],
      "object-curly-spacing": [
        2,
        "always"
      ],
      "comma-dangle": "off",
      "react/jsx-indent": [
        2,
        "tab"
      ],
      "react/jsx-indent-props": [
        2,
        "tab"
      ],
      "indent": [
        "error",
        "tab",
        {
          "SwitchCase": 1
        }
      ],
      "semi": "off"
    }
  }